<Window x:Class="Desktop_app.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="600" Width="600"
        WindowStartupLocation="CenterScreen"
        Icon="/Images/Logo.png">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Image Grid.Row="0" Source="/Images/Logo.png" HorizontalAlignment="Left" 
               VerticalAlignment="Top"
               Height="50" Width="50"/>
        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="30">
            <TextBlock Text="Вход в систему"  
                           FontSize="24" FontWeight="Bold" 
                           TextAlignment="Center"/>

                <TextBlock Text="Логин:" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameBox" 
                      Padding="10"
                     FontSize="14" Margin="0,0,0,15"
                     Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="1"/>

            <TextBlock Text="Пароль:" FontSize="14" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" 
                          Padding="10"
                         FontSize="14" Margin="0,0,0,20"
                         Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="1"/>

            <Button Content="Вход" Click="OnLoginClicked"
                    Height="40" Background="#FF6B35" Foreground="White"
                    FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock x:Name="ErrorMessage" Text="" Foreground="Red" FontSize="12"
                       TextWrapping="Wrap" Margin="0,10,0,0" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>