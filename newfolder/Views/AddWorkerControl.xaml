<UserControl x:Class="Desktop_app.Views.AddWorkerControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="White">
    <StackPanel Margin="20">
        <TextBlock Text="Добавить нового сотрудника" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="ФИО:" FontSize="12" Margin="0,0,0,5"/>
        <TextBox x:Name="FullNameBox" Padding="10" Margin="0,0,0,15"/>

        <TextBlock Text="Должность:" FontSize="12" Margin="0,0,0,5"/>
        <TextBox x:Name="JobPositionBox" Padding="10" Margin="0,0,0,15" />

        <TextBlock Text="Email:" FontSize="12" Margin="0,0,0,5"/>
        <TextBox x:Name="EmailBox" Padding="10" Margin="0,0,0,15" />

        <TextBlock Text="Рабочий телефон:" FontSize="12" Margin="0,0,0,5"/>
        <TextBox x:Name="WorkPhoneBox" Padding="10" Margin="0,0,0,10" />

        <TextBlock Text="Телефон:" FontSize="12" Margin="0,0,0,5"/>
        <TextBox x:Name="PhoneBox" Padding="10" Margin="0,0,0,10" />

        <TextBlock Text="Офис:" FontSize="12" Margin="0,0,0,5"/>
        <TextBox x:Name="OfficeBox" Padding="10" Margin="0,0,0,15"/>

        <TextBlock Text="Подразделение:" FontSize="12" Margin="0,0,0,5"/>
        <ComboBox x:Name="SubdepartmentCombo" Padding="10" Margin="0,0,0,15" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Click="OnSaveClicked" 
                    Background="#FF6B35" Foreground="White" Padding="20,10" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="OnCancelClicked"
                    Background="Gray" Foreground="White" Padding="20,10"/>
        </StackPanel>

        <TextBlock x:Name="ErrorMessage" Text="" Foreground="Red" Margin="0,15,0,0" TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>