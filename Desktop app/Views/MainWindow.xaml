<Window x:Class="Desktop_app.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АИС управление персоналом" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        MinHeight="450" MinWidth="900"
        Icon="/Images/Logo.png">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- SIDEBAR -->
        <StackPanel Grid.Column="0" Background="#F5F5F5" Margin="0" 
                    HorizontalAlignment="Left" Grid.RowSpan="2" Grid.Row="0">
            
            <Border Background="#FF6B35" Padding="15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Меню" FontSize="18" 
                               FontWeight="Bold" Foreground="White" 
                               TextWrapping="Wrap" VerticalAlignment="Center" Margin="20 0 0 0"/>
                </StackPanel>
            </Border>

            <Button x:Name="WorkerManagementBtn" Click="OnNavigate" Tag="WorkerManagement"
                    Height="50" Margin="0" Padding="15" 
                    HorizontalAlignment="Stretch" 
                    Background="White" BorderThickness="0"
                    FontSize="14" Foreground="Black">
                <TextBlock Text="👥 Управление персоналом" TextAlignment="Left" />
            </Button>

            <Button x:Name="DocumentsBtn" Click="OnNavigate" Tag="Documents" 
                    Height="50" Margin="0" Padding="15" 
                    HorizontalAlignment="Left" 
                    Background="White" BorderThickness="0"
                    FontSize="14" Foreground="Black">
                <TextBlock Text="📄 Документы" TextAlignment="Left"/>
            </Button>

            <Button x:Name="NewsBtn" Click="OnNavigate" Tag="News" 
                    Height="50" Margin="0" Padding="15" 
                    HorizontalAlignment="Left" 
                    Background="White" BorderThickness="0"
                    FontSize="14" Foreground="Black">
                <TextBlock Text="📰 Новости" TextAlignment="Left"/>
            </Button>

            <Button x:Name="EventsBtn" Click="OnNavigate" Tag="Events" 
                    Height="50" Margin="0" Padding="15" 
                    HorizontalAlignment="Left" 
                    Background="White" BorderThickness="0"
                    FontSize="14" Foreground="Black">
                <TextBlock Text="📅 События" TextAlignment="Left"/>
            </Button>

            <Separator Margin="0,20"/>

            <Button x:Name="ExitBtn" Click="OnExit" 
                    Height="50" Margin="0" Padding="15" 
                    HorizontalAlignment="Left" 
                    Background="White" BorderThickness="0"
                    FontSize="14" Foreground="Black">
                <TextBlock Text="🚪 Выход" TextAlignment="Left"/>
            </Button>

            
        </StackPanel>

        <!-- CONTENT AREA -->
        <ContentControl x:Name="ContentArea" Grid.Column="1" Grid.Row="0"/>
    </Grid>
</Window>