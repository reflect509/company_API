<UserControl x:Class="Desktop_app.Views.WorkerEvents"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="White">
        <StackPanel Margin="30">
            <Border Background="#FF6B35" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                <TextBlock x:Name="TitleBlock" Text="События сотрудника" 
                           FontSize="18" FontWeight="Bold" Foreground="White"/>
            </Border>

            <Button Content="← Назад" Click="OnBackClicked" 
                    Background="#FF6B35" Foreground="White"
                    Padding="15,10" Width="100" HorizontalAlignment="Left"
                    Margin="0,0,0,20"/>

            <DataGrid x:Name="EventsDataGrid" AutoGenerateColumns="False"
          CanUserAddRows="False" CanUserDeleteRows="False"
          Background="White" GridLinesVisibility="All"
          BorderBrush="#CCCCCC" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding EventId}" Width="50"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding EventName}" Width="*"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding EventType}" Width="150"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="150"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="300"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock x:Name="EmptyMessage" Text="Нет событий для этого сотрудника" 
                       FontSize="14" Foreground="Gray" Margin="0,20,0,0"
                       Visibility="Collapsed" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>