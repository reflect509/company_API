<UserControl x:Class="Desktop_app.Views.WorkersListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#FF6B35" Padding="20" Grid.Row="0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="👥 Сотрудники" 
                           FontSize="18" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button Content="➕ Добавить сотрудника" Click="OnAddWorkerClicked"
                        Background="White" Foreground="#FF6B35"
                        Padding="15,8" FontSize="12" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <ListBox x:Name="WorkersListBox" Grid.Row="1"
                 Margin="20"
                 Background="LightGray"
                 HorizontalContentAlignment="Stretch"
                 ItemsSource="{Binding Workers}"
                 SelectedItem="{Binding SelectedWorker, Mode=TwoWay}"
                 IsSynchronizedWithCurrentItem="False">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="0.5">
                        <Grid Background="{StaticResource DarkOrangeBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="9"
                                       Text="{Binding SubdepartmentName}" Margin="10 10 0 0" Foreground="White"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="9"
                                       Text="{Binding JobPosition, StringFormat=' - {0}'}" Margin="10 10 0 0" Foreground="White"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FontSize="13"
                                       Text="{Binding FullName}" Margin="10 3 0 0" Foreground="White"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" FontSize="10"
                                       Text="{Binding WorkPhone}" Margin="10 3 0 0" Foreground="White"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="10"
                                       Text="{Binding Email}" Margin="10 3 0 0" Foreground="White"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" FontSize="9"
                                       Text="{Binding Office}" Margin="10 4 0 10" Foreground="White"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>