<Window x:Class="Desktop_app.Views.CreateEvent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Desktop_app.Views"
        mc:Ignorable="d"
        Title="Создание события"
        Icon="/Images/Logo.png"
        Height="500"
        Width="500"
        WindowStartupLocation="CenterScreen"        
        Background="#F9F9F9"
        ResizeMode="NoResize">
    <Grid>
        <StackPanel Margin="30">
            <!-- Заголовок -->
            <TextBlock Text="Создание события"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       Margin="0 0 0 25"/>

            <!-- Тип события -->
            <StackPanel Margin="0 0 0 18">
                <TextBlock Text="Тип события"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#34495E"
                           Margin="0 0 0 6"/>
                <ComboBox Name="EventTypesCombobox"
                    ItemsSource="{Binding EventTypes}"
                          SelectedItem="{Binding SelectedEventType}"
                          Height="32"
                          Padding="10,8"
                          FontSize="12"
                          Background="White"
                          Foreground="#2C3E50"
                          BorderBrush="#D5D5D5"
                          BorderThickness="1">
                </ComboBox>
            </StackPanel>

            <!-- Дата -->
            <StackPanel Margin="0 0 0 18">
                <TextBlock Text="Дата события"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#34495E"
                           Margin="0 0 0 6"/>
                <DatePicker SelectedDate="{Binding EventDate}"
                            Height="50"
                            Padding="10,8"
                            FontSize="12"
                            Background="White"
                            Foreground="#2C3E50"
                            BorderBrush="#D5D5D5"
                            BorderThickness="1"/>
            </StackPanel>

            <!-- Описание -->
            <StackPanel Margin="0 0 0 25">
                <TextBlock Text="Описание события"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#34495E"
                           Margin="0 0 0 6"/>
                <TextBox Text="{Binding Description}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="90"
                         Padding="10,8"
                         FontSize="12"
                         Background="White"
                         Foreground="#2C3E50"
                         BorderBrush="#D5D5D5"
                         BorderThickness="1"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>

            <!-- Кнопки -->
            <Grid Margin="0 15 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Content="Отмена"
                        Command="{Binding CancelCommand}"
                        Width="100"
                        Height="36"
                        Margin="0 0 12 0"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="#95A5A6"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button Grid.Column="2"
                        Content="Создать"
                        Command="{Binding SaveCommand}"
                        Width="100"
                        Height="36"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="{StaticResource DarkOrangeBrush}"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
